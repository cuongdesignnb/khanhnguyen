# Sao chép file này thành .env.production rồi thay toàn bộ CHANGE_ME.
# Chỉ dùng ký tự hex cho mật khẩu PostgreSQL để DATABASE_URL không cần URL encode.

APP_PORT=4317
APP_IMAGE=ghcr.io/cuongdesignnb/khanhnguyen
APP_IMAGE_TAG=master
APP_ENV=production
NEXT_PUBLIC_SITE_URL=https://xenangkhanhnguyen.com
BETTER_AUTH_URL=https://xenangkhanhnguyen.com

POSTGRES_DB=khanhnguyen
POSTGRES_USER=khanhnguyen
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_HEX
DATABASE_URL=postgresql://khanhnguyen:CHANGE_ME_POSTGRES_HEX@postgres:5432/khanhnguyen?schema=public

# Tạo bằng: openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME_AUTH_SECRET
# Tạo bằng: openssl rand -base64 48
AI_SETTINGS_SECRET=CHANGE_ME_AI_SECRET
# Tạo bằng: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_CRON_SECRET

OPENAI_API_KEY=
OPENAI_BASE_URL=https://modelapi.vn/v1
OPENAI_WIRE_API=chat_completions
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_MAX_TOKENS=4096
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

ADMIN_EMAIL=admin@xenangkhanhnguyen.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_NAME="Quản trị viên"

UPLOAD_DIR=public/uploads
MAX_UPLOAD_SIZE_MB=20

# db push cần thiết vì repo hiện chưa có Prisma migrations.
RUN_DB_PUSH=false
# Chỉ bật true ở lần đầu nếu muốn nạp toàn bộ dữ liệu seed mẫu.
RUN_DB_SEED=false
